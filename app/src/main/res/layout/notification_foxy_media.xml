<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root"
    android:layout_width="match_parent"
    android:layout_height="184dp"
    android:background="@drawable/notification_foxy_bg">

    <ImageView
        android:id="@+id/notif_artwork_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/notif_top_play"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:alpha="0.9"
                android:background="@drawable/notification_foxy_pill"
                android:contentDescription="@string/playback_notification_app"
                android:padding="8dp"
                android:src="@drawable/ic_media_play" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/notif_device"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/notification_foxy_pill"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="This phone"
                android:textColor="#302B3A"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notif_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.78"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/notif_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Previous"
                android:padding="6dp"
                android:src="@drawable/ic_media_prev" />

            <ProgressBar
                android:id="@+id/notif_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/notification_progress_bg" />

            <ImageView
                android:id="@+id/notif_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Next"
                android:padding="6dp"
                android:src="@drawable/ic_media_next" />

            <ImageView
                android:id="@+id/notif_play_pause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/notification_foxy_play_bg"
                android:contentDescription="Play"
                android:padding="14dp"
                android:src="@drawable/ic_media_play" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
